{
  "manifest_version": 3,
  "name": "VibeX",
  "version": "1.0",
  "description": "The AI copilot for X creators. Automate viral replies, smart posts, and audience growth while you sleep.",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms",
    "sidePanel",
    "power",
    "identity"
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://*.x.com/*",
    "*://twitter.com/*",
    "*://*.twitter.com/*",
    "https://api.x.com/*",
    "https://api.twitter.com/*",
    "https://twitter.com/*",
    "https://*.chromiumapp.org/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://dashscope.aliyuncs.com/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://datahub.codes/*",
    "https://r.jina.ai/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_title": "VibeX: AI Copilot for X Growth"
  },
  "options_page": "options/options.html",
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "options/options.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://*.twitter.com/*"
      ],
      "js": [
        "core/automationState.js",
        "content/logic/evaluator.js",
        "content/x_scraper.js",
        "content/x_automator.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icons/icon-48.png",
        "assets/icons/icon-128.png"
      ],
      "matches": [
        "*://x.com/*",
        "*://*.x.com/*",
        "*://twitter.com/*",
        "*://*.twitter.com/*"
      ]
    }
  ]
}
